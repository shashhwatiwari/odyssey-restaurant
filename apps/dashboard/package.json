{
  "name": "@ody/dashboard",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "jest"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/vector-icons": "^14.0.4",
    "@ody/api-client": "workspace:*",
    "@ody/shared": "workspace:*",
    "@ody/types": "workspace:*",
    "@tanstack/react-query": "^5.50.0",
    "axios": "^1.7.0",
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.7",
    "react-native-web": "~0.19.13"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((?:\\.pnpm/[^/]*/node_modules/)?)((jest-)?react-native|@react-native|expo(nent)?|@expo(nent)?/|@testing-library|@unimodules|sentry-expo|native-base|react-native-svg))"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.3.0",
    "@types/react-dom": "~18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.5.0"
  }
}
