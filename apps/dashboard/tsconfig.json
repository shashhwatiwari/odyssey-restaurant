{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": [
      "jest"
    ],
    "paths": {
      "@ody/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@ody/types": [
        "../../packages/types/src/index.ts"
      ],
      "@ody/api-client": [
        "../../packages/api-client/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
